// Questions organized by level (1-20), 10 questions per level = 200 total questions
// Each level has variety: text, image, half-image, clubs, events, red cards, missed games

export const getGuessWhoQuestionsByLevel = (level: number): Question[] => {
  // Get questions for the specific level (10 questions per level)
  const levelQuestions = guessWhoQuestions.filter(q => {
    const questionLevel = parseInt(q.id.split('-')[2] || '1', 10);
    return questionLevel === level;
  });
  
  return levelQuestions.length > 0 ? levelQuestions : [];
};
